# Backend Environment Variables
PORT=5000
NODE_ENV=production

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/MERN_STACK_HOSPITAL_MANAGEMENT_SYSTEM?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET_KEY=your_very_secure_jwt_secret_key_change_this
JWT_EXPIRES=7d
COOKIE_EXPIRE=7

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URLs (for CORS)
FRONTEND_URL_ONE=https://yourdomain.com
FRONTEND_URL_TWO=https://admin.yourdomain.com

# Optional: Rate limiting and API throttling
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Email configuration (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
